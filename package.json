{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/ts-lib-crypto/issues"
  },
  "dependencies": {
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  },
  "description": "Official TypeScript cryptographic library for the DecentralChain blockchain — key generation, digital signatures, hashing, encoding, and encryption primitives for building secure dApps and protocol integrations.",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "fast-check": "4.5.3",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./bytes": {
      "types": "./dist/bytes.d.mts",
      "default": "./dist/bytes.mjs"
    },
    "./rsa": {
      "types": "./dist/rsa.d.mts",
      "default": "./dist/rsa.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/ts-lib-crypto#readme",
  "keywords": [
    "decentralchain",
    "dcc",
    "blockchain",
    "crypto",
    "cryptography",
    "protocol",
    "binary",
    "signature",
    "digital-signature",
    "wallet",
    "hashing",
    "encryption",
    "blake2b",
    "keccak",
    "sha256",
    "aes",
    "rsa",
    "bls12-381",
    "base58",
    "ed25519",
    "curve25519",
    "mnemonic",
    "seed-phrase",
    "key-generation",
    "typescript"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/ts-lib-crypto",
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/ts-lib-crypto.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "ignore": [
        "crypto"
      ],
      "limit": "150 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.0.1"
}
